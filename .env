RATE_LIMIT_TEST_API_KEY_SCRAPE=
RATE_LIMIT_TEST_API_KEY_CRAWL=

# Scraping services
SCRAPING_BEE_API_KEY=
SELF_HOSTED_WEBHOOK_URL=

# LLM / NLP integrations
OPENAI_API_KEY=
OPENAI_BASE_URL=           # ← WARN対策
MODEL_NAME=                # ← WARN対策
MODEL_EMBEDDING_NAME=      # ← WARN対策
OLLAMA_BASE_URL=           # ← WARN対策

# Alternative search engine (SearXNG)
